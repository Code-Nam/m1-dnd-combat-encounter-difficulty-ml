# Configuration de l'API de prédiction.
# Copier ce fichier en .env (même dossier) et adapter si besoin.

# Chemin du modèle entraîné, relatif à la racine du projet.
MODEL_PATH=models/xgboost_difficulty.joblib

# Origines autorisées pour CORS, séparées par des virgules.
# "*" autorise tout (pratique en dev). En production, lister explicitement :
# CORS_ORIGINS=https://mon-site.example,http://localhost:5173
CORS_ORIGINS=*
